<%- include('partials/header') %>

  <main>
    <h1>
      <%= title %>
    </h1>

    <section class="profile-info">
      <p><strong>Name:</strong>
        <%= user.name %>
      </p>
      <p><strong>Email:</strong>
        <%= user.email %>
      </p>
      <p><strong>Account Level:</strong> <span
          class="role-badge <%= user.role_name === 'admin' ? 'badge-admin' : 'badge-user' %>">
          <%= user.role_name %>
        </span></p>
    </section>

    <% if (user && user.role_name==='admin' ) { %>
      <section class="admin-actions">
        <h3>Admin Management</h3>
        <div class="buttons">
          <button type="button"><a href="/users">View Users</a></button>
          <button type="button"><a href="/organizations">View Organizations</a></button>
          <button type="button"><a href="/projects">View Projects</a></button>
          <button type="button"><a href="/categories">View Categories</a></button>
        </div>
      </section>
      <% } %>

        <hr>

        <section class="volunteering-section">
          <div class="section-header">
            <h2>Your Volunteering Commitments</h2>
            <span class="commitment-count">
              <%= volunteeredProjects.length %> Projects
            </span>
          </div>
        
          <% if (volunteeredProjects && volunteeredProjects.length> 0) { %>
            <div class="volunteer-grid">
              <% volunteeredProjects.forEach(project=> { %>
                <div class="volunteer-card">
                  <div class="card-content">
                    <span class="org-name">
                      <%= project.organization_name || 'Community Project' %>
                    </span>
                    <h3 class="project-title">
                      <%= project.title %>
                    </h3>
                  
                    <i><p>
                      <%= project.description.length > 100 ? project.description.substring(0, 100) + '...' : project.description %>
                    </p></i>
                  </div>
        
                  <div class="card-actions">
                    <a href="/project/<%= project.project_id %>" class="btn-view">Details</a>
        
                    <form action="/volunteer/remove/<%= project.project_id %>" method="POST" class="form-button">
                      <input type="hidden" name="source" value="dashboard">
                      <button type="submit" class="btn-remove-alt">Remove</button>
                    </form>
                  </div>
                </div>
                <% }) %>
                <div class="empty-state">
                  <a href="/projects" class="btn-primary">Add more projects</a>
                </div>
            </div>
            <% } else { %>
              <div>
                <p>You haven't signed up for any projects yet.</p>
                <a href="/projects" class="btn-primary">Find a Project</a>
              </div>
              <% } %>
        </section>

        <section class="buttons" style="margin-top: 3rem;">
          <button type="button" class="btn-link">
            <a href="/logout">Logout</a>
          </button>
        </section>
  </main>

  <%- include('partials/footer') %>