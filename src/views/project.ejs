<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>
    
    <section class="project-info">
        <p>
            <strong>Date:</strong> 
            <%= new Date(project.date).toLocaleDateString('en-US', { 
                month: 'long', 
                day: 'numeric', 
                year: 'numeric' 
            }) %>
        </p>
        
        <p><strong>Location:</strong> <%= project.location %></p>
        
        <p>
            <strong>Partner Organization:</strong> 
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <hr>

        <h3>Description</h3>
        <p><%= project.description %></p>
        <div class="project-tags">
            <h3>Categories:</h3>
            <div class="tags-container">
                <% assignedCategories.forEach(cat => { %>
                    <a href="/category/<%= cat.category_id %>" class="tag">
                        <%= cat.category_name %>
                    </a>
                <% }) %>
            </div>
        </div>
    </section>
    
    <section class="buttons">
        <button>
            <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
        </button>
        
        <button>
            <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
        </button>

        <button>
            <a href="/projects">← Back to Upcoming Projects</a>
        </button>
    </section>
</main>

<%- include('partials/footer') %>